# Publishable values only (baked into the bundle). NO server secrets — RLS + signature checks guard.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=https://YOURPROJECT.functions.supabase.co
# Cloudflare Turnstile site key (public). Leave unset to disable the bot check locally.
VITE_TURNSTILE_SITE_KEY=
# Paddle client-side token (public; `test_…` for sandbox, `live_…` for production). Used only by the
# /pay checkout bridge to open the Paddle overlay. NOT the server API key.
VITE_PADDLE_CLIENT_TOKEN=
